
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NAVODAYA MEMORIES YEARBOOK - MASTER ARCHIVE ACCESS (V32)
     * Last Deployment Sync: Force-pushed archival management permissions.
     * Deployment Goal: Ensure administrators can moderate all records without conflict.
     */

    match /{document=**} {
      // Global permissive access to ensure archival integrity and moderation.
      allow read, write: if true;
    }
  }
}
