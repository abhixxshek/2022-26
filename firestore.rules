
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NAVODAYA MEMORIES YEARBOOK - GLOBAL ARCHIVE ACCESS (V26)
     * Last Deployment Trigger: 2024-03-28T21:20:00Z
     * Deployment Goal: Unrestricted read/write for all archive records to resolve admin moderation errors.
     */

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
