
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NAVODAYA MEMORIES YEARBOOK - PUBLIC ACCESS RULES (V23)
     * Deployment Trigger: Open access to resolve permission errors and support public browsing.
     */

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
