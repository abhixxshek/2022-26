
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if the user is the owner of the document
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Student Profiles / Identity Records
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isOwner(studentId) || get(/databases/$(database)/documents/students/$(request.auth.uid)).data.role == "admin");
    }

    // The Journey (Historical Chronicles)
    match /journey/{yearId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // The Vault (Media Gallery)
    match /photos/{photoId} {
      allow read: if true;
      allow write: if isSignedIn();
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.uploadedByStudentId || get(/databases/$(database)/documents/students/$(request.auth.uid)).data.role == "admin");
    }

    // The Wall (Reflections & Goodbyes)
    match /memories/{memoryId} {
      allow read: if true;
      allow write: if isSignedIn();
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.studentId || get(/databases/$(database)/documents/students/$(request.auth.uid)).data.role == "admin");
    }
  }
}
