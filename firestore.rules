rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/students/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/students/$(request.auth.uid)).data.role == 'admin';
    }

    // GECian identity records
    match /students/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
      
      // Guestbook messages
      match /messages/{messageId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (request.auth.uid == userId || resource.data.senderId == request.auth.uid || isAdmin());
      }
    }

    // 4-Year Journey milestones
    match /journey/{yearId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Media Vault visuals
    match /photos/{photoId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.resource.data.uploadedByStudentId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && (resource.data.uploadedByStudentId == request.auth.uid || isAdmin());
    }

    // Reflection Wall memories
    match /memories/{memoryId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.resource.data.studentId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && (resource.data.studentId == request.auth.uid || isAdmin());
    }
  }
}