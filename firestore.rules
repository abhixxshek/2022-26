rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if the user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/students/$(request.auth.uid)).data.role == 'admin';
    }

    // Students Collection: Profiles and Roles
    match /students/{userId} {
      allow get, list: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // Journey Collection: The 7-Year History
    match /journey/{yearId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Allow all batch members to contribute to the history
    }

    // Photos Collection: The Media Vault
    match /photos/{photoId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.uploadedByStudentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Memories Collection: The Reflection Wall
    match /memories/{memoryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && request.resource.data.studentId == request.auth.uid);
      allow delete: if isAdmin();
    }
  }
}