rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NAVODAYA MEMORIES SECURITY RULES
     *
     * Core Philosophy:
     * This ruleset implements a "Yearbook" model. All authenticated users can view profiles, memories, 
     * quotes, and highlights to foster a sense of community. However, write access is strictly 
     * restricted to the owner of the specific profile.
     *
     * Data Structure:
     * - /studentProfiles/{studentProfileId}: The root document for a user's presence.
     * - /studentProfiles/{studentProfileId}/memories/{memoryId}: User-contributed stories.
     * - /studentProfiles/{studentProfileId}/quotes/{quoteId}: Memorable sayings.
     * - /studentProfiles/{studentProfileId}/highlights/{highlightId}: Key achievements.
     * - /classYears/{classYearId}: Shared reference data for academic years.
     *
     * Key Security Decisions:
     * 1. Public Read (Authenticated): Any signed-in user can read any profile or memory.
     * 2. Strict Ownership: Write operations are only permitted if the 'studentProfileId' 
     *    matches the authenticated user's UID.
     * 3. Static Reference Data: The 'classYears' collection is read-only for users.
     *
     * Denormalization for Authorization:
     * To ensure high performance and avoid expensive get() calls, every sub-document 
     * (Memory, Quote, Highlight) includes a 'studentProfileId' field. This field is validated 
     * against the path and the user's UID during creation and is immutable thereafter.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner of an existing document. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the student's primary profile document.
     * @path /studentProfiles/{studentProfileId}
     * @allow (create) if auth.uid matches studentProfileId.
     * @deny (update) if auth.uid does not match the existing document's ID.
     * @principle Enforces path-based ownership and validates relational integrity of the ID.
     */
    match /studentProfiles/{studentProfileId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(studentProfileId) && request.resource.data.id == studentProfileId;
      allow update: if isExistingOwner(studentProfileId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(studentProfileId);

      /**
       * @description User-contributed memories associated with their profile.
       * @path /studentProfiles/{studentProfileId}/memories/{memoryId}
       * @allow (list) if user is signed in (Yearbook style).
       * @deny (create) if studentProfileId in data doesn't match the path.
       * @principle Uses denormalized studentProfileId for owner-based write authorization.
       */
      match /memories/{memoryId} {
        allow get, list: if isSignedIn();
        allow create: if isOwner(studentProfileId) && request.resource.data.studentProfileId == studentProfileId;
        allow update: if isExistingOwner(studentProfileId) && request.resource.data.studentProfileId == resource.data.studentProfileId;
        allow delete: if isExistingOwner(studentProfileId);
      }

      /**
       * @description User-contributed quotes associated with their profile.
       * @path /studentProfiles/{studentProfileId}/quotes/{quoteId}
       * @allow (get) if user is signed in.
       * @deny (update) if attempting to change the studentProfileId link.
       * @principle Enforces ownership and immutability of the relational link.
       */
      match /quotes/{quoteId} {
        allow get, list: if isSignedIn();
        allow create: if isOwner(studentProfileId) && request.resource.data.studentProfileId == studentProfileId;
        allow update: if isExistingOwner(studentProfileId) && request.resource.data.studentProfileId == resource.data.studentProfileId;
        allow delete: if isExistingOwner(studentProfileId);
      }

      /**
       * @description User-contributed highlights and achievements.
       * @path /studentProfiles/{studentProfileId}/highlights/{highlightId}
       * @allow (create) if the user owns the parent profile path.
       * @deny (delete) if the user is not the owner.
       * @principle Restricts modification of personal highlights to the profile owner.
       */
      match /highlights/{highlightId} {
        allow get, list: if isSignedIn();
        allow create: if isOwner(studentProfileId) && request.resource.data.studentProfileId == studentProfileId;
        allow update: if isExistingOwner(studentProfileId) && request.resource.data.studentProfileId == resource.data.studentProfileId;
        allow delete: if isExistingOwner(studentProfileId);
      }
    }

    /**
     * @description Static reference data for academic years.
     * @path /classYears/{classYearId}
     * @allow (get, list) if user is signed in.
     * @deny (write) users are not permitted to modify global class metadata.
     * @principle Read-only access for reference data.
     */
    match /classYears/{classYearId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}