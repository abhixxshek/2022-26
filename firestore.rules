
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NAVODAYA MEMORIES YEARBOOK - SECURITY RULES (V18 - Admin Controls)
     */

    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/students/$(request.auth.uid)).data.role == 'admin';
    }

    match /students/{studentId} {
      allow get, list: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == studentId || isAdmin());
      allow delete: if isAdmin();
    }

    match /memories/{memoryId} {
      allow get, list: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.studentId == request.auth.uid;
      allow update: if request.auth != null && resource.data.studentId == request.auth.uid;
      allow delete: if isAdmin() || (request.auth != null && resource.data.studentId == request.auth.uid);
    }

    match /photos/{photoId} {
      allow get, list: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uploadedByStudentId == request.auth.uid;
      allow update: if request.auth != null && resource.data.uploadedByStudentId == request.auth.uid;
      allow delete: if isAdmin() || (request.auth != null && resource.data.uploadedByStudentId == request.auth.uid);
    }

    match /journey/{yearId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
