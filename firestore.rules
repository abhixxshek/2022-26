
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NAVODAYA MEMORIES YEARBOOK - GLOBAL ARCHIVE ACCESS (V27)
     * Last Deployment Trigger: 2024-03-28T22:30:00Z
     * Deployment Goal: Permissive read/write for all archive records.
     */

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
