
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NAVODAYA MEMORIES YEARBOOK - SECURITY RULES (V16 - Advanced Registration)
     * Explicitly separated read operations for robust archive browsing.
     */

    match /students/{studentId} {
      allow get, list: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == studentId;
    }

    match /memories/{memoryId} {
      allow get, list: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.studentId == request.auth.uid;
    }

    match /photos/{photoId} {
      // Explicitly allow get and list for authenticated students to browse the visual vault
      allow get, list: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uploadedByStudentId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uploadedByStudentId == request.auth.uid;
    }

    match /journey/{yearId} {
      allow read: if true; // Publicly viewable milestones for legacy
      allow write: if request.auth != null; // Authenticated students can maintain history
    }
  }
}
