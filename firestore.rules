rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NAVODAYA MEMORIES SECURITY RULES (REFINED)
     *
     * Core Philosophy:
     * This ruleset implements a "Yearbook" model. All authenticated users can view the archive.
     * Write access is governed by ownership or administrative role.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * @description Checks if the requesting user has administrative privileges.
     * This uses a direct get() on the students collection to verify the 'role' field.
     */
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/students/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Collection Rules ---

    /**
     * @description Master student records and profile identities.
     */
    match /students/{studentId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(studentId);
      allow update: if isOwner(studentId) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description The 7-year historical journey milestones.
     * Accessible for all authenticated students to contribute and refine.
     */
    match /journey/{yearId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    /**
     * @description The Media Vault (Photos).
     */
    match /photos/{photoId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    /**
     * @description The Reflection Wall (Memories).
     */
    match /memories/{memoryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    /**
     * @description Legacy support for studentProfiles (redirected to students).
     */
    match /studentProfiles/{profileId} {
      allow read, write: if isSignedIn();
    }
  }
}