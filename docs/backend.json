{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Represents a student's profile and identity within the Batch '25 archive.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "nickname": { "type": "string" },
        "email": { "type": "string" },
        "house": { "type": "string", "enum": ["Aravalli", "Nilgiri", "Shivalik", "Udaygiri"] },
        "role": { "type": "string", "enum": ["student", "admin"] },
        "batchId": { "type": "string" },
        "profilePhotoUrl": { "type": "string", "format": "uri" },
        "shortBio": { "type": "string" },
        "fullBio": { "type": "string" }
      },
      "required": ["id", "name", "role"]
    },
    "JourneyMilestone": {
      "title": "JourneyMilestone",
      "description": "A specific year in the 7-year JNV journey.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "order": { "type": "number" }
      }
    },
    "VaultPhoto": {
      "title": "VaultPhoto",
      "description": "A visual record stored in the media vault.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "caption": { "type": "string" },
        "classYearLabel": { "type": "string" },
        "uploadedByStudentId": { "type": "string" }
      }
    },
    "WallMemory": {
      "title": "WallMemory",
      "description": "A reflection note left on the public wall.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "studentName": { "type": "string" },
        "studentId": { "type": "string" },
        "classYearLabel": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/students/{studentId}",
        "definition": {
          "entityName": "Student",
          "schema": { "$ref": "#/backend/entities/Student" },
          "description": "Master identity records."
        }
      },
      {
        "path": "/journey/{yearId}",
        "definition": {
          "entityName": "JourneyMilestone",
          "schema": { "$ref": "#/backend/entities/JourneyMilestone" },
          "description": "The 7-year timeline."
        }
      },
      {
        "path": "/photos/{photoId}",
        "definition": {
          "entityName": "VaultPhoto",
          "schema": { "$ref": "#/backend/entities/VaultPhoto" },
          "description": "Archived visuals."
        }
      },
      {
        "path": "/memories/{memoryId}",
        "definition": {
          "entityName": "WallMemory",
          "schema": { "$ref": "#/backend/entities/WallMemory" },
          "description": "Public wall reflections."
        }
      }
    ]
  }
}